# Local development defaults. Copy to .env and fill in values.
# Never commit .env files or service-role keys.

APP_ENV=development
STORAGE_PROVIDER=local

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini

# Comma-separated frontend origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Public chat rate limiting (process-local safeguard)
CHAT_RATE_LIMIT_MAX_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=600

# Required only when STORAGE_PROVIDER=supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
